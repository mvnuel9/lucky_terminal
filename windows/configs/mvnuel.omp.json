{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "plain",
          "foreground": "#a8c870",
          "template": " \uf07b {{ .Path }} ",
          "properties": {
            "style": "folder",
            "max_width": 64,
            "folder_icon": "",
            "home_icon": "~"
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "status",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "default",
          "background": "#1a1210",
          "template": "{{ if gt .Code 0 }} \u2718 {{ .Code }} {{ end }}"
        },
        {
          "type": "root",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#e0a040",
          "background": "#1a1210",
          "template": " \u26a1 "
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#d4a060",
          "background": "#251810",
          "template": "{{ if .Venv }} {{ .Venv }} {{ end }}",
          "properties": {
            "fetch_virtual_env": true,
            "fetch_version": false,
            "display_mode": "environment",
            "folder_name_fallback": false
          }
        },
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#e0855a",
          "background": "#3a2a20",
          "template": " {{ .UserName }} ",
          "foreground_templates": [
            "{{ if .Root }}#d44040{{ else }}#e0855a{{ end }}"
          ]
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#AA2727",
          "background": "#d4a060",
          "template": " {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \u00b1{{ end }} ",
          "properties": {
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "branch_icon": "\ue0a0 "
          }
        }
      ]
    }
  ]
}
